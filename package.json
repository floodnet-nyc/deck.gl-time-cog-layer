{
  "name": "@floodnet/deck.gl-time-cog-layer",
  "version": "0.1.0",
  "type": "module",
  "description": "A deck.gl CompositeLayer for time-indexed Cloud-Optimized GeoTIFF playback.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json",
